# ── LLM ────────────────────────────────────────────────────────────────────
# Primary provider: openai | anthropic | local
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for local/proxy vLLM

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local vLLM (Ollama, vLLM, LMStudio — set LLM_PROVIDER=local)
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL=your-local-model-id

# ── Databases ───────────────────────────────────────────────────────────────
PORT=3001
MONGODB_URI=mongodb://localhost:27017/prospectiq
REDIS_URL=redis://localhost:6379

# ── Optional enrichment APIs ────────────────────────────────────────────────
# Leave blank to use LLM-only fallback
SERPAPI_KEY=
YOUTUBE_API_KEY=

# ── Server ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
